        "condition": "on_success",
        "description": "",
        "label": ""
      },
      {
        "id": "edge-3",
        "source": "lrs-dispatch",
        "target": "confirmation",
        "condition": "on_success",
        "description": "",
        "label": ""
      },
      {
        "id": "edge-4",
        "source": "confirmation",
        "target": "event-capture",
        "condition": "on_success",
        "description": "loop for next event",
        "label": "next event"
      }
    ],
    "entry_node": "event-capture",
    "terminal_nodes": [],
